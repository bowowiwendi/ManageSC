<!DOCTYPE html>
<html lang="id">
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <?!= include('Styles.html'); ?>
</head>
<body>
  <div class="container">
    <header>
      <h1>🖥️ Manajemen Penyewaan VPS</h1>
      <p>Aplikasi CRUD untuk program penyewaan VPS Limit & Unlimited</p>
    </header>

    <main>
      <!-- Top Button Group (Desktop) -->
      <div class="button-group">
        <button id="add-btn" class="btn btn-primary">➕ Tambah Penyewaan Baru</button>
        <button id="broadcast-btn" class="btn btn-info">📢 Broadcast Pesan</button>
        <button id="check-expired-btn" class="btn btn-warning">📧 Cek Akun Kadaluarsa</button>
      </div>

      <div id="notification" class="notification"></div>

      <!-- Search Bar -->
      <div class="search-container">
        <h3>Cari Data</h3>
        <div class="search-input-wrapper">
          <input type="text" id="search-input" class="search-input" placeholder="Cari berdasarkan username atau IP VPS...">
          <button id="search-btn" class="btn btn-primary search-btn">🔍 Cari</button>
        </div>
      </div>

      <!-- Filter Data -->
      <div class="filter-controls">
        <h3>Filter Data</h3>
        <div class="form-group-inline">
          <label for="filter-start-date">Dari Tanggal:</label>
          <input type="date" id="filter-start-date">
        </div>
        <div class="form-group-inline">
          <label for="filter-end-date">Sampai Tanggal:</label>
          <input type="date" id="filter-end-date">
        </div>
        <button id="apply-filter-btn" class="btn btn-secondary">Terapkan Filter</button>
        <button id="reset-filter-btn" class="btn btn-secondary">Reset</button>
      </div>

      <div class="table-container">
        <table id="data-table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Tipe Akun</th>
              <th>Masa Aktif</th>
              <th>IP VPS</th>
              <th>EMAIL MEMBER</th>
              <th>RAM</th>
              <th>Pesan</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody id="table-body">
            <!-- Data akan dimuat di sini oleh JavaScript -->
          </tbody>

          <!-- Pagination Footer -->
          <tfoot>
            <tr>
              <td colspan="8">
                <div class="pagination-wrapper">
                  <div id="pagination-info" class="pagination-info">
                    <!-- Info data akan dimuat di sini -->
                  </div>
                  <div id="pagination-controls" class="pagination-controls">
                    <!-- Kontrol tombol akan dimuat di sini oleh JavaScript -->
                    <button id="prev-page-btn" class="btn btn-secondary" disabled>&laquo; Sebelumnya</button>
                    <span id="page-numbers"></span>
                    <button id="next-page-btn" class="btn btn-secondary" disabled>Selanjutnya &raquo;</button>
                  </div>
                </div>
              </td>
            </tr>
          </tfoot>
        </table>
        <div id="loading-spinner" class="spinner"></div>
      </div>
    </main>
  </div>

  <!-- Bottom Navigation (Mobile) -->
  <nav class="bottom-nav">
    <div class="bottom-nav-items">
      <button class="bottom-nav-item active" data-action="home">
        <span class="nav-icon">🏠</span>
        <span>Home</span>
      </button>
      <button class="bottom-nav-item" data-action="add">
        <span class="nav-icon">➕</span>
        <span>Tambah</span>
      </button>
      <button class="bottom-nav-item" data-action="search">
        <span class="nav-icon">🔍</span>
        <span>Cari</span>
      </button>
      <button class="bottom-nav-item" data-action="broadcast">
        <span class="nav-icon">📢</span>
        <span>Broadcast</span>
      </button>
      <button class="bottom-nav-item" data-action="check">
        <span class="nav-icon">📧</span>
        <span>Cek</span>
      </button>
    </div>
  </nav>

  <!-- PIN Modal -->
  <div id="pin-modal" class="pin-modal">
    <div class="pin-modal-content">
      <h2>🔐 Keamanan</h2>
      <p>Masukkan PIN 6 digit untuk melanjutkan</p>
      <div class="pin-input-container">
        <input type="tel" class="pin-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" data-index="0">
        <input type="tel" class="pin-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" data-index="1">
        <input type="tel" class="pin-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" data-index="2">
        <input type="tel" class="pin-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" data-index="3">
        <input type="tel" class="pin-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" data-index="4">
        <input type="tel" class="pin-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" data-index="5">
      </div>
      <div class="pin-actions">
        <button id="cancel-pin-btn" class="btn btn-secondary">Batal</button>
        <button id="verify-pin-btn" class="btn btn-primary">Masuk</button>
      </div>
    </div>
  </div>

  <!-- Modal untuk Tambah/Edit Data -->
  <div id="form-modal" class="modal">
    <div class="modal-content">
      <span class="close-btn">&times;</span>
      <h2 id="modal-title">Tambah Penyewaan Baru</h2>
      <form id="data-form">
        <input type="hidden" id="data-id">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" required placeholder="Masukkan username">
        </div>
        <div class="form-group">
          <label for="tipeAkun">Tipe Akun</label>
          <select id="tipeAkun" required>
            <option value="">-- Pilih Tipe --</option>
            <option value="limit">#limit</option>
            <option value="unli">#unli (lifetime)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="masaAktifHari">Jumlah Hari (untuk #limit)</label>
          <input type="number" id="masaAktifHari" placeholder="Contoh: 30" disabled min="1">
          <small>Masa aktif dihitung dari hari ini.</small>
        </div>
        <div class="form-group">
          <label for="ipVps">IP VPS</label>
          <input type="text" id="ipVps" required placeholder="Contoh: 192.168.1.1">
        </div>
        <div class="form-group">
          <label for="emailMember">EMAIL MEMBER</label>
          <input type="email" id="emailMember" placeholder="member@example.com">
        </div>
        <div class="form-group">
          <label for="ram">RAM</label>
          <input type="text" id="ram" placeholder="Contoh: 2GB">
        </div>
        <div class="form-group">
          <label for="pesan">Pesan (untuk broadcast)</label>
          <textarea id="pesan" rows="3" placeholder="Pesan khusus untuk member ini (jika ada)"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-success">💾 Simpan</button>
          <button type="button" class="btn btn-secondary cancel-btn">Batal</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Konfirmasi Hapus -->
  <div id="delete-modal" class="modal">
    <div class="modal-content">
      <h2>⚠️ Konfirmasi Hapus</h2>
      <p>Apakah Anda yakin ingin menghapus data ini? Tindakan ini tidak dapat dibatalkan.</p>
      <div class="form-actions">
        <button id="confirm-delete-btn" class="btn btn-danger">🗑️ Hapus</button>
        <button class="btn btn-secondary cancel-btn">Batal</button>
      </div>
    </div>
  </div>

  <!-- Modal Renew -->
  <div id="renew-modal" class="modal">
    <div class="modal-content">
      <h2>🔄 Perpanjang Masa Aktif</h2>
      <p>Masukkan jumlah hari yang ingin ditambahkan.</p>
      <form id="renew-form">
        <div class="form-group">
          <label for="renew-hari">Jumlah Hari</label>
          <input type="number" id="renew-hari" placeholder="Contoh: 30" required min="1">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-success">🔄 Perpanjang</button>
          <button type="button" class="btn btn-secondary cancel-btn">Batal</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Broadcast -->
  <div id="broadcast-modal" class="modal">
    <div class="modal-content">
      <h2>📢 Kirim Broadcast ke Semua Member</h2>
      <p>Masukkan pesan yang akan dikirim ke semua member yang memiliki alamat email.</p>
      <form id="broadcast-form">
        <div class="form-group">
          <label for="broadcast-message-text">Pesan Broadcast</label>
          <textarea id="broadcast-message-text" rows="5" placeholder="Tulis pesan Anda di sini..." required></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-success">📢 Kirim</button>
          <button type="button" class="btn btn-secondary cancel-btn">Batal</button>
        </div>
      </form>
    </div>
  </div>

  <?!= include('JavaScript.html'); ?>
</body>
</html>